"VertexlitGeneric"
{
	"$baseTexture" "models\weapons\c_items/c_longshot_clip"

	"$phong" "1"
	"$phongexponent" "25"
	"$phongboost" ".8"	
	"$lightwarptexture" "models\lightwarps\weapon_lightwarp"
	"$phongfresnelranges"	"[1.5 2 2.5]"
	"$basemapalphaphongmask" "1"	
	"$halflambert" "1"

	"$rimlight" "1"						
	"$rimlightexponent" "1"				
	"$rimlightboost" "0.125"



	// Cloaking
	"$cloakPassEnabled" "1"
	"Proxies"
	{
		"weapon_invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
	}
}
